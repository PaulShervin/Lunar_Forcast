# Demo Mode Flag
# Set to "true"  → Demo Mode ON
# Set to "false" → Demo Mode OFF
VITE_DEMO_MODE=true

# Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
